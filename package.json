{
  "name": "wafer-agentic-ui",
  "version": "0.1.0",
  "private": true,
  "packageManager": "pnpm@10.12.0",
  "scripts": {
    "build": "turbo run build",
    "dev": "turbo run dev --parallel",
    "dev:playground": "turbo run dev --filter=playground",
    "hooks:install": "bash ./scripts/install-git-hooks.sh",
    "release:check": "pnpm run build && pnpm run typecheck && mkdir -p .release/tarballs && pnpm -r --filter \"./packages/*\" pack --pack-destination .release/tarballs",
    "release:publish": "pnpm run build && pnpm run typecheck && pnpm -r --filter \"./packages/*\" publish --access public",
    "typecheck": "turbo run typecheck",
    "lint": "biome check apps/ packages/",
    "lint:fix": "biome check --write apps/ packages/",
    "scan:secrets": "bash ./scripts/scan-secrets.sh",
    "test": "turbo run test"
  },
  "devDependencies": {
    "@biomejs/biome": "^2.4.16",
    "@types/node": "^24.0.0",
    "turbo": "^2.5.4",
    "typescript": "^6.0.0"
  }
}
