{
  "name": "@wafer/react",
  "version": "0.1.0",
  "type": "module",
  "sideEffects": false,
  "main": "./dist/index.cjs",
  "module": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.js",
      "require": "./dist/index.cjs"
    }
  },
  "files": [
    "dist"
  ],
  "scripts": {
    "build": "tsup",
    "typecheck": "tsc -p tsconfig.json --noEmit",
    "lint": "echo \"No lint configured for @wafer/react\"",
    "test": "vitest run --coverage"
  },
  "peerDependencies": {
    "react": "^19.0.0"
  },
  "dependencies": {
    "@wafer/core": "workspace:*",
    "@wafer/protocol": "workspace:*"
  },
  "devDependencies": {
    "@testing-library/jest-dom": "^6.9.1",
    "@testing-library/react": "^16.3.2",
    "@testing-library/user-event": "^14.6.1",
    "@types/react": "^19.1.8",
    "jsdom": "^29.1.1",
    "react": "^19.2.0",
    "tsup": "^8.5.0",
    "typescript": "^6.0.0"
  }
}
