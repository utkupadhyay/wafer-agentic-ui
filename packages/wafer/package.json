{
  "name": "wafer",
  "version": "0.1.0",
  "description": "Agentic UI toolkit for React — single-package install.",
  "type": "module",
  "sideEffects": false,
  "main": "./dist/index.cjs",
  "module": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.js",
      "require": "./dist/index.cjs"
    },
    "./adapters/ollama": {
      "types": "./dist/adapters/ollama.d.ts",
      "import": "./dist/adapters/ollama.js",
      "require": "./dist/adapters/ollama.cjs"
    },
    "./adapters/groq": {
      "types": "./dist/adapters/groq.d.ts",
      "import": "./dist/adapters/groq.js",
      "require": "./dist/adapters/groq.cjs"
    }
  },
  "files": ["dist"],
  "scripts": {
    "build": "tsup",
    "typecheck": "tsc -p tsconfig.json --noEmit",
    "lint": "echo \"No lint configured for wafer\""
  },
  "peerDependencies": {
    "react": "^19.0.0"
  },
  "dependencies": {
    "@wafer/adapters": "workspace:*",
    "@wafer/core": "workspace:*",
    "@wafer/react": "workspace:*",
    "@wafer/ui": "workspace:*"
  },
  "devDependencies": {
    "@types/react": "^19.1.8",
    "react": "^19.2.0",
    "tsup": "^8.5.0",
    "typescript": "^6.0.0"
  }
}
