{
  "name": "@wafer/ui",
  "version": "0.1.0",
  "type": "module",
  "main": "./dist/index.cjs",
  "module": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.js",
      "require": "./dist/index.cjs"
    }
  },
  "files": ["dist"],
  "scripts": {
    "build": "tsup src/index.ts --format esm,cjs --dts --sourcemap --clean",
    "typecheck": "tsc -p tsconfig.json --noEmit",
    "lint": "echo \"No lint configured for @wafer/ui\"",
    "test": "echo \"No tests configured for @wafer/ui\""
  },
  "peerDependencies": {
    "react": "^19.0.0"
  },
  "dependencies": {
    "@wafer/react": "workspace:*"
  },
  "devDependencies": {
    "@types/react": "^19.1.8",
    "react": "^19.2.0",
    "tsup": "^8.5.0",
    "typescript": "^6.0.0"
  }
}
